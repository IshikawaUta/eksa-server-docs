    <header class="pt-48 pb-24 px-6 text-center relative overflow-hidden">
        <div class="absolute inset-0 z-[-2] opacity-20">
            <img src="/hero.png" class="w-full h-full object-cover" alt="">
        </div>
        <div class="max-w-4xl mx-auto">
            <h1 class="text-6xl md:text-8xl font-black mb-6 tracking-tighter">
                Server Web <span class="gradient-text">Profesional</span> <br/>untuk Ruby.
            </h1>
            <p class="text-xl text-slate-400 mb-10 leading-relaxed max-w-2xl mx-auto">
                Mesin server web modular asinkron dengan performa tinggi, dirancang khusus untuk kecepatan dan kemudahan integrasi.
            </p>
            <div class="flex flex-wrap items-center justify-center gap-4">
                <a href="/installation" class="px-8 py-4 bg-indigo-600 hover:bg-indigo-500 text-white font-bold rounded-2xl transition shadow-xl shadow-indigo-600/20 flex items-center gap-2">
                    <i data-lucide="code" class="w-5 h-5"></i> Mulai Sekarang
                </a>
                <div class="px-8 py-4 glass text-slate-300 font-mono rounded-2xl border border-white/10">
                    gem install eksa_server
                </div>
            </div>
        </div>
    </header>

    <main class="max-w-5xl mx-auto px-6 space-y-32 pb-32">
        <!-- Introduction -->
        <section id="intro" class="grid md:grid-cols-2 gap-12 items-center">
            <div>
                <h2 class="text-3xl font-bold mb-6 flex items-center gap-3">
                    <i data-lucide="zap" class="text-indigo-400"></i> Mengapa EksaServer?
                </h2>
                <ul class="space-y-6">
                    <li class="flex gap-4">
                        <div class="p-3 glass rounded-xl text-indigo-400"><i data-lucide="cpu" class="w-6 h-6"></i></div>
                        <div>
                            <h3 class="font-bold text-lg">Asinkron & NIO</h3>
                            <p class="text-slate-400">Berbasis nio4r untuk menangani ribuan koneksi secara efisien.</p>
                        </div>
                    </li>
                    <li class="flex gap-4">
                        <div class="p-3 glass rounded-xl text-indigo-400"><i data-lucide="layers" class="w-6 h-6"></i></div>
                        <div>
                            <h3 class="font-bold text-lg">Cluster Mode</h3>
                            <p class="text-slate-400">Mendukung banyak worker process untuk memanfaatkan semua core CPU Anda.</p>
                        </div>
                    </li>
                    <li class="flex gap-4">
                        <div class="p-3 glass rounded-xl text-indigo-400"><i data-lucide="refresh-cw" class="w-6 h-6"></i></div>
                        <div>
                            <h3 class="font-bold text-lg">Phased Restarts</h3>
                            <p class="text-slate-400">Update kode aplikasi tanpa mematikan server (Zero Downtime).</p>
                        </div>
                    </li>
                </ul>
            </div>
            <div class="glass-dark rounded-3xl p-8 border border-white/5 relative overflow-hidden group">
                <div class="absolute inset-0 bg-indigo-500/5 group-hover:bg-indigo-500/10 transition"></div>
                <div class="relative z-10 space-y-4">
                    <div class="flex gap-2">
                        <div class="w-3 h-3 rounded-full bg-red-500"></div>
                        <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                        <div class="w-3 h-3 rounded-full bg-green-500"></div>
                    </div>
                    <pre class="overflow-x-auto text-sm"><code><span class="text-indigo-400">threads</span> 5, 20
<span class="text-indigo-400">workers</span> 2
<span class="text-indigo-400">bind</span> "tcp://0.0.0.0:3000"

<span class="text-pink-400">on_worker_boot</span> do |index|
  puts "Worker #{index} siap!"
end</code></pre>
                    <p class="text-xs text-center text-slate-500 uppercase tracking-widest font-bold">Arsitektur Modular</p>
                </div>
            </div>
        </section>
    </main>
